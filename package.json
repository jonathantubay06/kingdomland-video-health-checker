{
  "name": "kingdomland-video-checker",
  "version": "1.0.0",
  "description": "This tool automatically opens a browser, logs into go.kingdomlandkids.com, clicks on every single video (all 125), and checks if it loads. At the end, you get a report showing which ones pass and which ones fail — so you don't have to check them one by one.",
  "main": "check-videos.js",
  "scripts": {
    "start": "node server.js",
    "check": "node check-videos.js",
    "check:debug": "node check-videos.js --debug",
    "check:story": "node check-videos.js --story",
    "check:music": "node check-videos.js --music",
    "check:firefox": "node check-videos.js --browser=firefox",
    "check:webkit": "node check-videos.js --browser=webkit",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "daily-summary": "node daily-summary.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "node-cron": "^4.2.1",
    "playwright": "^1.59.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "@types/node-cron": "^3.0.11",
    "@types/web-push": "^3.6.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
