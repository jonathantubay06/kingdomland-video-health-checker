# Kingdomland Video Checker — Environment Variables
# Copy this file to .env and fill in your values

# ===== Required (for running checks) =====
KL_USERNAME=your-kingdomland-email@example.com
KL_PASSWORD=your-password

# ===== Required (for Netlify cloud mode) =====
GITHUB_TOKEN=ghp_your-github-personal-access-token
GITHUB_REPO=your-username/kingdomland-video-checker

# ===== Required (for Spreadsheet Cross-check) =====
# Google Spreadsheet ID (from the URL: docs.google.com/spreadsheets/d/THIS_PART/edit)
GSHEET_SPREADSHEET_ID=1WnDBxVpXdaDQd5PBLGKC1VzuF1DDTODRmyW-TUjqjc0

# ===== Optional =====
# Google Apps Script web app URL (for auto-updating spreadsheet statuses)
# Deploy google-apps-script.js as a web app and paste the URL here
# GSHEET_WEBAPP_URL=https://script.google.com/macros/s/.../exec

# Webhook URL for notifications (Slack, Discord, or any endpoint)
# WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
